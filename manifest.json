{
  "id": "wealthfolio-spending",
  "name": "Spending",
  "version": "1.0.0",
  "description": "Personal Finance Tracking",
  "author": "Cloudburst",
  "main": "dist/addon.js",
  "sdkVersion": "1.0.0",
  "enabled": true,
  "permissions": [
    {
      "category": "ui",
      "functions": ["sidebar.addItem"],
      "purpose": "Add navigation items to the sidebar"
    },
    {
      "category": "accounts",
      "functions": ["getAll"],
      "purpose": "Retrieve account list for filtering"
    },
    {
      "category": "portfolio",
      "functions": ["getHistoricalValuations"],
      "purpose": "Calculate spending from valuation history"
    },
    {
      "category": "settings",
      "functions": ["get"],
      "purpose": "Retrieve user currency preferences"
    }
  ],
  "keywords": ["wealthfolio", "addon"],
  "license": "MIT"
}
